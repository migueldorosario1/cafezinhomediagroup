---

<!DOCTYPE html>
<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Optimization -->
		<title>Cafezinho Media Group | Central de Portais de Mídia Independente</title>
		<meta name="description" content="Central de links e rede de portais independentes do Cafezinho Media Group, cobrindo geopolítica, política nacional, ferrovias, tecnologia e dados urbanos." />
		<meta name="robots" content="index, follow" />
		<meta property="og:title" content="Cafezinho Media Group | Central de Portais de Mídia Independente" />
		<meta property="og:description" content="Central de links e rede de portais independentes do Cafezinho Media Group, cobrindo geopolítica, política nacional, ferrovias, tecnologia e dados urbanos." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://cafezinhomediagroup.vercel.app" />
		<meta name="twitter:card" content="summary_large_image" />
		
	</head>
	<body>
		<div class="bg-glow-orb-1"></div>
		<div class="bg-glow-orb-2"></div>
		<div class="bg-grid-overlay"></div>

		<!-- Nav -->
		<header>
			<div class="app-container">
				<div class="nav-wrapper">
					<a href="/" class="brand" id="brand-link">
						<div class="brand-logo-icon">C</div>
						<div class="brand-text">Cafezinho <span>Media Group</span></div>
					</a>
				</div>
			</div>
		</header>

		<main class="app-container">
			<!-- Hero Section -->
			<section class="hero" id="hero-section">
				<div class="hero-tag">Portfólio de Rede</div>
				<h1 id="main-heading">
					<span class="gradient-text">Conectando</span> 
					<span class="accent-text">Informação</span><br />
					<span class="gradient-text">e Geopolítica Independente</span>
				</h1>
				<p class="hero-subtitle">
					Navegue pela nossa rede de portais temáticos e canais independentes especializados em análise política, economia, ferrovias, tecnologia e dados cariocas.
				</p>

				<!-- Filter Buttons -->
				<div class="filter-container" id="filter-controls">
					<button class="filter-btn active" data-filter="all" id="filter-all">Todos os Sites</button>
					<button class="filter-btn" data-filter="pt" id="filter-pt">Em Português</button>
					<button class="filter-btn" data-filter="en" id="filter-en">In English</button>
					<button class="filter-btn" data-filter="specialized" id="filter-specialized">Especializados</button>
					<button class="filter-btn" data-filter="interativo" id="filter-interativo">Dados Interativos</button>
				</div>
			</section>

			<!-- Portals Grid -->
			<section class="portals-grid" id="portals-directory">
				{portals.map((portal) => (
					<a 
						href={portal.url} 
						target="_blank" 
						rel="noopener noreferrer" 
						class="portal-card" 
						data-lang={portal.lang} 
						data-type={portal.type}
						id={`card-${portal.id}`}
					>
						<div class="card-header">
							<div class="card-icon" set:html={portal.icon}></div>
							<span class="card-badge">{portal.badge}</span>
						</div>
						<div class="card-body">
							<h2 class="card-title">{portal.name}</h2>
							<div class="card-slogan">{portal.slogan}</div>
							<p class="card-description">{portal.description}</p>
						</div>
						<div class="card-footer">
							<span>Acessar Portal</span>
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<line x1="5" y1="12" x2="19" y2="12"></line>
								<polyline points="12 5 19 12 12 19"></polyline>
							</svg>
						</div>
					</a>
				))}
			</section>
		</main>

		<!-- Footer -->
		<footer>
			<div class="app-container">
				<div class="footer-content">
					<div class="footer-logo">Cafezinho <span>Media Group</span></div>
					<p class="footer-desc">
						Uma rede integrada de mídias independentes dedicadas ao debate crítico, infraestrutura estratégica de transportes, geopolítica internacional sob a ótica do Sul Global e o desenvolvimento de Inteligências Artificiais autônomas para comunicação.
					</p>
					<div class="footer-meta">
						&copy; {new Date().getFullYear()} Cafezinho Media Group. Todos os direitos reservados.
					</div>
				</div>
			</div>
		</footer>

		<!-- Client side Script for Card Effects and Filters -->
		<script>
			// Card hover spot illumination effect
			const cards = document.querySelectorAll('.portal-card');
			cards.forEach(card => {
				card.addEventListener('mousemove', (e) => {
					const rect = card.getBoundingClientRect();
					const x = e.clientX - rect.left;
					const y = e.clientY - rect.top;
					(card as HTMLElement).style.setProperty('--x', `${x}px`);
					(card as HTMLElement).style.setProperty('--y', `${y}px`);
				});
			});

			// Filter actions
			const filterButtons = document.querySelectorAll('.filter-btn');
			filterButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					// Active state toggles
					filterButtons.forEach(b => b.classList.remove('active'));
					btn.classList.add('active');

					const filterValue = btn.getAttribute('data-filter');

					cards.forEach(card => {
						const type = card.getAttribute('data-type');
						const lang = card.getAttribute('data-lang');

						let show = false;
						if (filterValue === 'all') {
							show = true;
						} else if (filterValue === 'pt' && lang === 'pt') {
							show = true;
						} else if (filterValue === 'en' && lang === 'en') {
							show = true;
						} else if (filterValue === 'specialized' && type === 'specialized') {
							show = true;
						} else if (filterValue === 'interativo' && type === 'interactive') {
							show = true;
						}

						if (show) {
							card.classList.remove('hidden');
						} else {
							card.classList.add('hidden');
						}
					});
				});
			});
		</script>
	</body>
</html>
